# /etc/default/thriftyx-capture@<rxid>
# Copy to /etc/default/thriftyx-capture@rx0 (etc.) and edit.

THRIFTYX_USER=pi
THRIFTYX_HOME=/home/pi/thrifty-x
THRIFTYX_CONFIG=/var/lib/thriftyx/capture.cfg
THRIFTYX_OUT=/var/lib/thriftyx

# Headless matplotlib (analysis tools called from same env)
MPLBACKEND=Agg
