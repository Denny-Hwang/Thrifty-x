# /etc/default/thriftyx-heartbeat
THRIFTYX_HOME=/home/pi/thrifty-x
THRIFTYX_RXID=0
THRIFTYX_OUT=/var/lib/thriftyx
THRIFTYX_UNIT=thriftyx-capture@rx0.service

# Optional: POST heartbeat JSON to this URL each tick.
# Leave unset to log to journald only.
# THRIFTYX_HEARTBEAT_URL=https://example.org/thriftyx/heartbeat
